# DZ-Sentry — copy to .env.local

# LLM for Semantic Search → "Synthesize answer" (RAG)
# Use Gemini OR Claude. If both are set, Gemini is preferred unless LLM_PROVIDER forces one.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Optional Claude fallback / alternative
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Supabase (schema in /supabase/schema.sql)
# Without these, the prototype uses local demo auth + JSON RAG store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
